{
  "name": "jturbide-gulp",
  "version": "1.0.1",
  "description": "A TypeScript-based Gulp setup class to streamline common tasks like compiling Sass, bundling/minifying JavaScript, optimizing images, processing HTML views, and copying files. The main goal is to reduce repetitive boilerplate and centralize Gulp task configuration.",
  "author": "Julien Turbide",
  "license": "BSD-3-Clause",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jturbide/gulp.git"
  },
  "bugs": {
    "url": "https://github.com/jturbide/gulp/issues"
  },
  "homepage": "https://github.com/jturbide/gulp#readme",
  "packageManager": "pnpm@11.12.0",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "workspaces": [
    "tests"
  ],
  "scripts": {
    "build": "rollup -c",
    "check": "tsc --noEmit",
    "test:integration": "pnpm --filter jturbide-gulp-demo run build",
    "test": "pnpm run check && pnpm run build && pnpm run test:integration",
    "prepack": "rollup -c"
  },
  "browserslist": [
    "last 2 versions",
    "> 2%"
  ],
  "dependencies": {
    "@types/browser-sync": "^2.29.0",
    "@types/gulp": "^4.0.17",
    "@types/gulp-changed": "^0.0.39",
    "@types/gulp-concat": "^0.0.37",
    "@types/gulp-dart-sass": "^1.0.5",
    "@types/gulp-debug": "^2.0.36",
    "@types/gulp-file-include": "^0.14.8",
    "@types/gulp-gzip": "^0.0.36",
    "@types/gulp-header": "^2.0.4",
    "@types/gulp-htmlmin": "^1.3.36",
    "@types/gulp-if": "^3.0.4",
    "@types/gulp-imagemin": "^8.0.6",
    "@types/gulp-newer": "^1.4.3",
    "@types/gulp-plumber": "^0.0.37",
    "@types/gulp-postcss": "^8.0.6",
    "@types/gulp-rename": "^2.0.6",
    "@types/gulp-sourcemaps": "^0.0.38",
    "@types/gulp-strip-debug": "^1.1.35",
    "@types/gulp-terser": "^1.2.6",
    "@types/gulp-uglify": "^3.0.11",
    "@types/html-minifier": "^4.0.6",
    "@types/minimist": "^1.2.5",
    "@types/vinyl": "^2.0.12",
    "@types/vinyl-fs": "^3.0.8",
    "autoprefixer": "^10.4.16",
    "browser-sync": "^3.0.2",
    "cssnano": "^7.0.5",
    "del": "^7.1.0",
    "gulp": "^5.0.0",
    "gulp-avif": "^1.1.1",
    "gulp-brotli": "^3.0.0",
    "gulp-changed": "^5.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-dart-sass": "^1.1.0",
    "gulp-debug": "^5.0.1",
    "gulp-deporder": "^1.2.0",
    "gulp-file-include": "^2.3.0",
    "gulp-gzip": "^1.4.2",
    "gulp-header": "^2.0.9",
    "gulp-htmlmin": "^5.0.1",
    "gulp-i18n-localize": "^1.4.0",
    "gulp-if": "^3.0.0",
    "gulp-imagemin": "^9.1.0",
    "gulp-newer": "^1.4.0",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-strip-debug": "^6.0.0",
    "gulp-terser": "^2.1.0",
    "gulp-uglify": "^3.0.2",
    "gulp-webp": "^5.0.0",
    "minimist": "^1.2.8",
    "postcss": "^8.4.41",
    "postcss-sort-media-queries": "^5.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.20.0",
    "tslib": "^2.6.3",
    "typescript": "^5.9.3"
  }
}
